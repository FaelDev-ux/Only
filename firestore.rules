rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/users/$(adminEmail()));
    }

    function adminDocExists() {
      return adminEmail() != ""
        && exists(/databases/$(database)/documents/users/$(adminEmail()));
    }

    function currentUserDisabled() {
      return signedIn()
        && adminDocExists()
        && adminDoc().data.disabled == true;
    }

    function isAdmin() {
      return signedIn()
        && adminDocExists()
        && !currentUserDisabled()
        && adminDoc().data.isAdmin == true;
    }

    function canAccessCash() {
      return signedIn()
        && adminDocExists()
        && !currentUserDisabled()
        && (
          adminDoc().data.isAdmin == true
          || adminDoc().data.canAccessCash == true
        );
    }

    function validShortText(value, max) {
      return value is string && value.size() > 0 && value.size() <= max;
    }

    function validOptionalText(value, max) {
      return !(value is string) || value.size() <= max;
    }

    function validPaymentValue(value) {
      return value is string
        && value in ['pix', 'dinheiro', 'cartao'];
    }

    function validImageField(value) {
      return value is string
        && value.size() <= 500000
        && (
          value == ""
          || value.matches('^https?://.*')
          || value.matches('^data:image/.*')
        );
    }

    function validPriceText(value) {
      return value is string
        && value.size() >= 1
        && value.size() <= 20
        && value.matches('^[0-9]+([\\.,][0-9]{1,2})?$');
    }

    function validSubProductsField(value) {
      return value is list
        && value.size() <= 20;
    }

    function validProductPayload() {
      return request.resource.data.keys().hasOnly([
          'title',
          'category',
          'price',
          'image',
          'details',
          'subProducts',
          'available',
          'createdAt'
        ])
        && validShortText(request.resource.data.title, 120)
        && validShortText(request.resource.data.category, 60)
        && validPriceText(request.resource.data.price)
        && validImageField(request.resource.data.image)
        && validOptionalText(request.resource.data.details, 1000)
        && (
          !request.resource.data.keys().hasAny(['subProducts'])
          || validSubProductsField(request.resource.data.subProducts)
        )
        && request.resource.data.available is bool;
    }

    function validCustomerPayload() {
      return request.resource.data.customer is map
        && request.resource.data.customer.keys().hasOnly([
          'name',
          'phone',
          'payment',
          'cep',
          'address',
          'addressNumber',
          'district',
          'complement',
          'notes',
          'city',
          'state'
        ])
        && validShortText(request.resource.data.customer.name, 120)
        && validShortText(request.resource.data.customer.phone, 20)
        && validPaymentValue(request.resource.data.customer.payment)
        && validShortText(request.resource.data.customer.cep, 10)
        && validShortText(request.resource.data.customer.address, 180)
        && validShortText(request.resource.data.customer.addressNumber, 20)
        && validShortText(request.resource.data.customer.district, 120)
        && validOptionalText(request.resource.data.customer.complement, 120)
        && validOptionalText(request.resource.data.customer.notes, 500)
        && validOptionalText(request.resource.data.customer.city, 120)
        && validOptionalText(request.resource.data.customer.state, 10);
    }

    function validOrderPayload() {
        return request.resource.data.keys().hasOnly([
          'orderCode',
          'items',
          'subtotal',
          'discount',
          'surcharge',
          'total',
          'customer',
          'createdAt',
          'printCompleted',
          'printedAt'
        ])
        && validShortText(request.resource.data.orderCode, 20)
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 20
        && request.resource.data.subtotal is number
        && request.resource.data.subtotal >= 0
        && request.resource.data.subtotal <= 100000
        && request.resource.data.discount is number
        && request.resource.data.discount >= 0
        && request.resource.data.discount <= 100000
        && request.resource.data.surcharge is number
        && request.resource.data.surcharge >= 0
        && request.resource.data.surcharge <= 100000
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.total <= 100000
        && request.resource.data.total
          == request.resource.data.subtotal - request.resource.data.discount + request.resource.data.surcharge
        && (!request.resource.data.keys().hasAny(['printCompleted'])
          || request.resource.data.printCompleted == false)
        && (!request.resource.data.keys().hasAny(['printedAt'])
          || request.resource.data.printedAt == null)
        && validCustomerPayload();
    }

    function validCashSalePayload() {
      return request.resource.data.keys().hasOnly([
          'orderCode',
          'sessionId',
          'items',
          'subtotal',
          'discount',
          'surcharge',
          'total',
          'payment',
          'customerName',
          'notes',
          'source',
          'createdAt'
        ])
        && validShortText(request.resource.data.orderCode, 20)
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 30
        && validShortText(request.resource.data.sessionId, 120)
        && request.resource.data.subtotal is number
        && request.resource.data.subtotal >= 0
        && request.resource.data.subtotal <= 100000
        && request.resource.data.discount is number
        && request.resource.data.discount >= 0
        && request.resource.data.discount <= 100000
        && request.resource.data.surcharge is number
        && request.resource.data.surcharge >= 0
        && request.resource.data.surcharge <= 100000
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.total <= 100000
        && request.resource.data.total
          == request.resource.data.subtotal - request.resource.data.discount + request.resource.data.surcharge
        && validPaymentValue(request.resource.data.payment)
        && validOptionalText(request.resource.data.customerName, 120)
        && validOptionalText(request.resource.data.notes, 500)
        && request.resource.data.source == 'caixa';
    }

    function validCashSessionCreatePayload() {
      return request.resource.data.keys().hasOnly([
          'status',
          'openingAmount',
          'openedAt',
          'openedByName',
          'openedByEmail'
        ])
        && request.resource.data.status == 'open'
        && request.resource.data.openingAmount is number
        && request.resource.data.openingAmount >= 0
        && request.resource.data.openingAmount <= 100000
        && validShortText(request.resource.data.openedByName, 120)
        && validShortText(request.resource.data.openedByEmail, 200)
        && request.resource.data.openedByEmail == adminEmail();
    }

    function validCashSessionUpdatePayload() {
      return request.resource.data.keys().hasOnly([
          'status',
          'openingAmount',
          'openedAt',
          'openedByName',
          'openedByEmail',
          'closedAt',
          'closedByName',
          'closedByEmail',
          'sessionOrdersCount',
          'sessionCashSalesCount',
          'onlineOrdersTotal',
          'cashSalesTotal',
          'moneyPaymentsTotal',
          'pixPaymentsTotal',
          'cardPaymentsTotal',
          'totalMovement',
          'expectedClosingBalance'
        ])
        && request.resource.data.status == 'closed'
        && request.resource.data.openingAmount == resource.data.openingAmount
        && request.resource.data.openedAt == resource.data.openedAt
        && request.resource.data.openedByName == resource.data.openedByName
        && request.resource.data.openedByEmail == resource.data.openedByEmail
        && validShortText(request.resource.data.closedByName, 120)
        && validShortText(request.resource.data.closedByEmail, 200)
        && request.resource.data.closedByEmail == adminEmail()
        && request.resource.data.sessionOrdersCount is number
        && request.resource.data.sessionOrdersCount >= 0
        && request.resource.data.sessionCashSalesCount is number
        && request.resource.data.sessionCashSalesCount >= 0
        && request.resource.data.onlineOrdersTotal is number
        && request.resource.data.onlineOrdersTotal >= 0
        && request.resource.data.cashSalesTotal is number
        && request.resource.data.cashSalesTotal >= 0
        && request.resource.data.moneyPaymentsTotal is number
        && request.resource.data.moneyPaymentsTotal >= 0
        && request.resource.data.pixPaymentsTotal is number
        && request.resource.data.pixPaymentsTotal >= 0
        && request.resource.data.cardPaymentsTotal is number
        && request.resource.data.cardPaymentsTotal >= 0
        && request.resource.data.totalMovement is number
        && request.resource.data.totalMovement >= 0
        && request.resource.data.expectedClosingBalance is number
        && request.resource.data.expectedClosingBalance >= 0;
    }

    match /users/{email} {
      allow read: if signedIn() && (email == adminEmail() || isAdmin());

      allow create: if signedIn()
        && email == adminEmail()
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'photoURL',
          'isAdmin',
          'canAccessCash',
          'disabled',
          'createdAt',
          'lastLoginAt'
        ])
        && request.resource.data.email == adminEmail()
        && request.resource.data.isAdmin == false
        && request.resource.data.canAccessCash == false
        && request.resource.data.disabled == false
        && validOptionalText(request.resource.data.displayName, 120)
        && validOptionalText(request.resource.data.photoURL, 2000);

      allow update: if signedIn()
        && email == adminEmail()
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'photoURL',
          'isAdmin',
          'canAccessCash',
          'disabled',
          'createdAt',
          'lastLoginAt'
        ])
        && request.resource.data.email == resource.data.email
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.canAccessCash == resource.data.canAccessCash
        && request.resource.data.disabled == resource.data.disabled
        && request.resource.data.createdAt == resource.data.createdAt
        && validOptionalText(request.resource.data.displayName, 120)
        && validOptionalText(request.resource.data.photoURL, 2000);

      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if canAccessCash() || resource.data.available == true;
      allow create, update: if isAdmin() && validProductPayload();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if validOrderPayload();
      allow read: if canAccessCash();
      allow update, delete: if isAdmin();
    }

    match /cashSales/{saleId} {
      allow read: if canAccessCash();
      allow delete: if isAdmin();
      allow create, update: if canAccessCash() && validCashSalePayload();
    }

    match /cashSessions/{sessionId} {
      allow read: if canAccessCash();
      allow delete: if isAdmin();
      allow create: if canAccessCash() && validCashSessionCreatePayload();
      allow update: if canAccessCash() && validCashSessionUpdatePayload();
    }
  }
}
