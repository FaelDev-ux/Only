rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : "";
    }

    function isAdmin() {
      return signedIn()
        && adminEmail() != ""
        && exists(/databases/$(database)/documents/adminUsers/$(adminEmail()))
        && (
          get(/databases/$(database)/documents/adminUsers/$(adminEmail())).data.isAdmin == true
          || get(/databases/$(database)/documents/adminUsers/$(adminEmail())).data.active == true
        );
    }

    match /adminUsers/{email} {
      allow read: if signedIn() && email == adminEmail();
      allow create: if signedIn()
        && email == adminEmail()
        && request.resource.data.email == adminEmail()
        && request.resource.data.isAdmin == false;
      allow update: if signedIn()
        && email == adminEmail()
        && request.resource.data.email == resource.data.email
        && request.resource.data.isAdmin == resource.data.isAdmin
        && (
          !("active" in resource.data)
          || request.resource.data.active == resource.data.active
        );
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if isAdmin() || resource.data.available == true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
